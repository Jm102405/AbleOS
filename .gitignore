# ============================================
# V1 Able OS — .gitignore
# Stack: React + Vite + TypeScript + Tailwind
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/

# Environment variables — NEVER commit
.env
.env.local
.env.development
.env.production
.env.*.local
*.env

# Vite cache
.vite/
vite.config.ts.timestamp-*

# TypeScript
*.tsbuildinfo

# Cache
.cache/
.eslintcache
.stylelintcache

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# Editor / IDE
.vscode/
.idea/
*.suo
*.swp
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Deployment
.netlify/
.vercel/

# Testing
coverage/
